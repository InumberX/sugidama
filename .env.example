# Build-time variables consumed by vite.config.ts via Vite's loadEnv.
# For local deploys, copy to `.env.development.local` or `.env.production.local`
# and fill in the values matching the target environment.
# CI builds inject these via GitHub Environment variables, so .env files
# are only needed for local `npm run deploy:*` invocations.

NO_INDEX=
SITE_URL=
SITE_NAME=
GOOGLE_ANALYTICS_ID=
API_URL=
