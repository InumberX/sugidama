# Build-time variables consumed by vite.config.ts via Vite's loadEnv.
# For local builds (`npm start`, `npm run deploy-*`), copy this file to
# `.env.development.local` or `.env.production.local` and fill in the values
# matching the target environment.
# CI builds inject these via GitHub Environment variables, so the .env files
# are only needed for local invocations of any script that bundles the worker.

NO_INDEX=
SITE_URL=
SITE_NAME=
GOOGLE_ANALYTICS_ID=
API_URL=
