{
  "name": "@InumberX/sugidama",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "cross-env NODE_ENV=production react-router build",
    "build-development": "cross-env CLOUDFLARE_ENV=development npm run build",
    "build-production": "cross-env CLOUDFLARE_ENV=production npm run build",
    "dev": "react-router dev",
    "start": "cross-env NODE_ENV=production CLOUDFLARE_ENV=development wrangler dev",
    "deploy-development": "npm run build-development && cross-env NODE_ENV=production CLOUDFLARE_ENV=development wrangler deploy --env=development",
    "deploy-production": "npm run build-production && cross-env NODE_ENV=production CLOUDFLARE_ENV=production wrangler deploy --env=production",
    "typecheck": "npm run react-router-typegen && tsc -b",
    "format": "oxfmt --check \"./{app,tests,stories,.storybook,workers}/**/*.{ts,tsx}\"",
    "format-fix": "oxfmt --write \"./{app,tests,stories,.storybook,workers}/**/*.{ts,tsx}\"",
    "lint": "oxlint ./app/ ./tests/ ./stories/ ./.storybook/ ./workers/ --max-warnings=0",
    "lint-fix": "oxlint --fix ./app/ ./tests/ ./stories/ ./.storybook/ ./workers/",
    "test": "vitest",
    "storybook": "storybook dev --no-open -p 6006 -c .storybook",
    "upgrade": "npx npm-check-updates -u",
    "upgrade-check": "npx npm-check-updates",
    "pre-commit": "npm run typecheck && npm run lint-fix && npm run format-fix",
    "react-router-typegen": "react-router typegen",
    "react-router-typegen-watch": "react-router typegen --watch"
  },
  "dependencies": {
    "@conform-to/react": "^1.19.4",
    "@conform-to/zod": "^1.19.4",
    "@date-fns/tz": "^1.5.0",
    "@inumberx/cloudflare-workers-basic-auth": "^1.0.0",
    "cookie": "^2.0.0",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.0",
    "i18next": "^26.3.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "isbot": "^5.1.44",
    "keen-slider": "^6.8.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router": "^8.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@cloudflare/workers-types": "^4.20260626.1",
    "@react-router/dev": "^8.0.1",
    "@react-router/fs-routes": "^8.0.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/css": "^1.21.0",
    "@vanilla-extract/vite-plugin": "^5.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^10.1.0",
    "csstype": "^3.2.3",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "storybook": "^10.4.6",
    "typescript": "6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  },
  "overrides": {
    "vite-plugin-devtools-json": {
      "vite": "$vite"
    }
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "volta": {
    "node": "22.20.0"
  }
}
