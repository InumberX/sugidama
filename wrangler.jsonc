{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sugidama",
  "compatibility_date": "2026-05-04",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./workers/app.ts",
  "assets": {
    "directory": "./build/client",
  },
  "observability": {
    "enabled": true,
  },
  "env": {
    "development": {
      "name": "dev-sugidama",
    },
    "production": {
      "name": "sugidama",
    },
  },
}
